# Backend
APP_SECURITY_PRODUCTION=false
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:4200
OPENAPI_ENABLED=true

# Database - PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/dash_api
DB_USERNAME=postgres
DB_PASSWORD=change-me
JPA_SHOW_SQL=false

# JWT
JWT_SECRET=change-me-use-at-least-32-characters
JWT_ISSUER=planno-tasks-api
JWT_EXPIRATION_HOURS=2

# Uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# Platform billing
PLATFORM_BILLING_ADMIN_TENANT_SLUG=planno-local
PLATFORM_PLAN_CODE=planno-tasks-pro-monthly
PLATFORM_PLAN_NAME=Planno Tasks Pro
PLATFORM_MONTHLY_PRICE=39.90
PLATFORM_CURRENCY_ID=BRL
PLATFORM_BILLING_MANAGE_URL=http://localhost:4200/workspace-plan
PLATFORM_BILLING_NOTIFICATION_URL=http://localhost:8080/api/platform-billing/webhooks/mercado-pago

# Mercado Pago - enable only after configuring real credentials outside git
MERCADO_PAGO_ENABLED=false
MERCADO_PAGO_ACCESS_TOKEN=replace-with-provider-token
MERCADO_PAGO_WEBHOOK_SECRET=replace-with-webhook-secret
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_CURRENCY_ID=BRL
MERCADO_PAGO_SUCCESS_URL=http://localhost:4200/payments?status=success
MERCADO_PAGO_PENDING_URL=http://localhost:4200/payments?status=pending
MERCADO_PAGO_FAILURE_URL=http://localhost:4200/payments?status=failure
MERCADO_PAGO_SUBSCRIPTION_BACK_URL=http://localhost:4200/subscriptions
MERCADO_PAGO_NOTIFICATION_URL=

# Google Drive - enable only after configuring OAuth in Google Cloud
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CLIENT_ID=replace-with-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8080/api/integrations/google-drive/callback
GOOGLE_DRIVE_ROOT_FOLDER_ID=root
GOOGLE_DRIVE_AUTH_BASE_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_DRIVE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_DRIVE_USERINFO_URI=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_DRIVE_REVOKE_URI=https://oauth2.googleapis.com/revoke
GOOGLE_DRIVE_API_BASE_URL=https://www.googleapis.com
GOOGLE_DRIVE_SCOPES=openid,email,profile,https://www.googleapis.com/auth/drive
GOOGLE_DRIVE_FRONTEND_SUCCESS_URL=http://localhost:4200/documents?googleDrive=connected
GOOGLE_DRIVE_FRONTEND_ERROR_URL=http://localhost:4200/documents?googleDrive=error

# Google Calendar - can reuse Drive OAuth credentials only if the same OAuth app is configured for both redirects/scopes
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=replace-with-google-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_DEFAULT_CALENDAR_ID=primary
GOOGLE_CALENDAR_AUTH_BASE_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_CALENDAR_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_CALENDAR_USERINFO_URI=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_CALENDAR_REVOKE_URI=https://oauth2.googleapis.com/revoke
GOOGLE_CALENDAR_API_BASE_URL=https://www.googleapis.com
GOOGLE_CALENDAR_SCOPES=openid,email,profile,https://www.googleapis.com/auth/calendar
GOOGLE_CALENDAR_FRONTEND_SUCCESS_URL=http://localhost:4200/calendar?googleCalendar=connected
GOOGLE_CALENDAR_FRONTEND_ERROR_URL=http://localhost:4200/calendar?googleCalendar=error

# SMTP
MAIL_ENABLED=false
MAIL_FROM=no-reply@planno.local
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# Frontend build/runtime
PLANNO_API_BASE_URL=http://localhost:8080
